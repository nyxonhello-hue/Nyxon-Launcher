{
  "name": "nyxon-launcher",
  "version": "1.0.0",
  "description": "Nyxon — Cross-platform desktop automation launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.nyxon.launcher",
    "productName": "Nyxon Launcher",
    "asar": true,
    "asarUnpack": [
      "node_modules/@napi-rs/canvas*/**",
      "node_modules/muhammara/**",
      "node_modules/ffmpeg-static/**"
    ],
    "copyright": "Copyright © 2026 Nyxon",
    "files": [
      "**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "nyxonhello-hue",
      "repo": "nyxon-launcher"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "artifactName": "Nyxon-Launcher-Setup-${version}.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Nyxon-Launcher-${version}.${ext}",
      "icon": "assets/icon_512.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Nyxon-Launcher-${version}.${ext}",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "Nyxon-Launcher-${version}.${ext}",
      "icon": "assets/icon_512.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": {
    "name": "Nyxon",
    "email": "nyxon.hello@gmail.com"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "archiver": "^7.0.1",
    "axios": "^1.16.1",
    "cheerio": "^1.1.0",
    "dropbox": "^10.34.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "googleapis": "^171.4.0",
    "muhammara": "^6.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "qrcode": "^1.5.4",
    "sudo-prompt": "^9.2.1",
    "xlsx": "^0.18.5"
  }
}